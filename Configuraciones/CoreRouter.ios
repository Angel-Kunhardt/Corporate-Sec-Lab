en
conf t
hostname CoreRouter
no ip domain lookup
enable secret LabSec2025
line console 0
password LabSec2025
login
line vty 0 4
password LabSec2025
transport input ssh
login
banner motd $--- Unauthorized Access is Strictly Forbidden ---$
service password-encryption
username SSHadmin secret LabSec2025
ip domain name LabSec.Dev
crypto key generate rsa general-keys modulus 1024

ip route 0.0.0.0 0.0.0.0 172.16.0.9

int g0/0
ip add 172.16.0.10 255.255.255.252
description CoreRouter->Firewall
no sh
exit

int g1/0
no ip add
description CoreRouter->CoreSwitch
duplex full
ip helper-address 172.16.10.10
no sh
exit

router ospf 10
router-id 10.10.10.10
passive-int default
no passive-int g0/0
network 172.16.0.0 0.0.0.3 area 0
network 172.16.0.4 0.0.0.3 area 0
network 172.16.0.8 0.0.0.3 area 0
network 172.16.1.0 0.0.0.15 area 0
network 172.16.10.0 0.0.0.255 area 0
network 172.16.20.0 0.0.0.255 area 0


int g1/0.100
encapsulation dot1q 100 native
ip address 172.16.1.1 255.255.255.240
description VLAN 100 - Management
ip ospf 10 area 0

int g1/0.10
encapsulation dot1q 10
ip add 172.16.10.1 255.255.255.0
description VLAN 10 - DC
ip helper-address 172.16.10.10
ip ospf 10 area 0

int g1/0.20
encapsulation dot1q 20
ip address 172.16.20.1 255.255.255.0
description VLAN 20 - IT
ip helper-address 172.16.10.10
ip ospf 10 area 0
